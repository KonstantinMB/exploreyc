# =============================================================================
# Backend environment variables (copy to .env in repo root for local dev)
# =============================================================================

# --- Database ---------------------------------------------------------------
# Local dev: leave DATABASE_URL unset to use SQLite at backend/database.db
# Production (Supabase): use the "Connection pooling" URI (port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# Direct/session connection (port 5432) — required for migrations & long-running DDL.
# Copy DATABASE_URL and change :6543 to :5432.
DIRECT_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_KEY=your-supabase-service-role-key

# --- Admin dashboard --------------------------------------------------------
# Generate strong random values — these protect /api/admin/* routes.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me

# --- LLM / research providers ----------------------------------------------
# Required for /api/validate-idea and embedding generation.
OPENAI_API_KEY=sk-your-openai-key

# Optional. Used by /api/research and Perplexity-backed enrichment.
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Optional. Used by funding/people enrichment via CoreSignal.
CORESIGNAL_API_KEY=your-coresignal-key

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key

# --- App / cron -------------------------------------------------------------
# Frontend origin (used for CORS + email links). Use http://localhost:5173 locally.
FRONTEND_URL=http://localhost:5173

# Shared secret required as a Bearer token on /api/cron/* endpoints.
CRON_SECRET=generate-a-long-random-string

# =============================================================================
# Docker Compose
# =============================================================================
# DATABASE_URL is set automatically by docker-compose.yml — don't set it here
# for the Docker workflow. Override other vars by adding them to a .env file.
VITE_API_BASE_URL=http://backend:8000
