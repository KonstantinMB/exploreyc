# Frontend environment variables (copy to frontend/.env.local for local dev)

# Backend API URL. Leave unset locally — the Vite dev server proxies /api and
# /ws to http://localhost:8000. Set this in production (e.g. Render).
VITE_API_URL=https://your-backend.example.com

# Show "Share" link in the navbar. Default false.
VITE_SHOW_SHARE_NAV=false
